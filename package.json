{
  "name": "tla-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "nodemon --watch server/src --watch server/prisma --ext ts,json --exec \"node --import tsx server/src/index.ts\"",
    "start:server": "node --import tsx server/src/index.ts",
    "build": "vite build",
    "build:mobile": "vite build && npx cap sync",
    "build:server": "tsc -p server/tsconfig.json",
    "build:all": "npm run build && npm run build:server",
    "cap:sync": "npx cap sync",
    "cap:copy": "npx cap copy",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "prisma:generate": "prisma generate --schema server/prisma/schema.prisma",
    "prisma:format": "prisma format --schema server/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema server/prisma/schema.prisma",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/status-bar": "^8.0.2",
    "@primeuix/themes": "^2.0.3",
    "@primevue/themes": "^4.5.4",
    "@prisma/client": "^6.19.3",
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/pdfkit": "^0.17.6",
    "axios": "^1.18.1",
    "cors": "^2.8.6",
    "cropperjs": "^2.1.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pdfkit": "^0.19.1",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "swagger-ui-express": "^5.0.1",
    "tailwindcss": "^4.3.0",
    "tailwindcss-primeui": "^0.6.1",
    "vue": "^3.5.34",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitejs/plugin-vue": "^6.0.6",
    "msw": "^2.14.6",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vue-tsc": "^3.3.3"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}

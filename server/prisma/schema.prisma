generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id              String                       @id
  email           String                       @unique
  name            String?
  role            String                       @default("player")
  players         Player[]
  memberships     OrganizationMembership[]
  requestsCreated OrganizationRequest[]        @relation("RequestCreator")
  requestVotes    OrganizationRequestVote[]
  requestComments OrganizationRequestComment[]
  accessRequests  OrganizationAccessRequest[]
  createdAt       DateTime                     @default(now()) @map("created_at")
  updatedAt       DateTime                     @updatedAt @map("updated_at")

  @@map("profiles")
}

model Organization {
  id             String                      @id @default(uuid())
  name           String
  slug           String                      @unique
  description    String?
  city           String?
  sport          String?
  latitude       Float?                      @db.DoublePrecision
  longitude      Float?                      @db.DoublePrecision
  visibility     String                      @default("private")
  discoverable   Boolean                     @default(false)
  joinCode       String                      @unique @map("join_code")
  memberships    OrganizationMembership[]
  players        Player[]
  tournaments    Tournament[]
  requests       OrganizationRequest[]
  accessRequests OrganizationAccessRequest[]
  createdAt      DateTime                    @default(now()) @map("created_at")
  updatedAt      DateTime                    @updatedAt @map("updated_at")

  @@map("organizations")
}

model OrganizationAccessRequest {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  profileId      String       @map("profile_id")
  status         String       @default("pending")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  profile        Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([organizationId, profileId])
  @@index([organizationId, status])
  @@map("organization_access_requests")
}

model OrganizationRequest {
  id             String                       @id @default(uuid())
  organizationId String                       @map("organization_id")
  createdById    String                       @map("created_by_id")
  title          String
  description    String?
  type           String                       @default("improvement")
  priority       String                       @default("medium")
  status         String                       @default("open")
  imageUrl       String?                      @map("image_url")
  organization   Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      Profile                      @relation("RequestCreator", fields: [createdById], references: [id], onDelete: Cascade)
  votes          OrganizationRequestVote[]
  comments       OrganizationRequestComment[]
  createdAt      DateTime                     @default(now()) @map("created_at")
  updatedAt      DateTime                     @updatedAt @map("updated_at")

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("organization_requests")
}

model OrganizationRequestVote {
  requestId String              @map("request_id")
  profileId String              @map("profile_id")
  request   OrganizationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  profile   Profile             @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime            @default(now()) @map("created_at")

  @@id([requestId, profileId])
  @@index([profileId])
  @@map("organization_request_votes")
}

model OrganizationRequestComment {
  id        String              @id @default(uuid())
  requestId String              @map("request_id")
  profileId String              @map("profile_id")
  body      String
  request   OrganizationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  profile   Profile             @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  @@index([requestId, createdAt])
  @@map("organization_request_comments")
}

model OrganizationMembership {
  organizationId String       @map("organization_id")
  profileId      String       @map("profile_id")
  role           String       @default("member")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  profile        Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @map("created_at")

  @@id([organizationId, profileId])
  @@index([profileId])
  @@map("organization_memberships")
}

model Player {
  id               String             @id @default(uuid())
  name             String
  ranking          Int
  birthDate        DateTime?          @map("birth_date")
  photoUrl         String?            @map("photo_url")
  club             String?
  phone            String?
  organizationId   String?            @map("organization_id")
  userId           String?            @map("user_id")
  organization     Organization?      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  profile          Profile?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  entries          TournamentPlayer[]
  matchesAsPlayer1 Match[]            @relation("MatchPlayer1")
  matchesAsPlayer2 Match[]            @relation("MatchPlayer2")
  wonMatches       Match[]            @relation("MatchWinner")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  @@unique([organizationId, userId])
  @@index([ranking])
  @@index([organizationId])
  @@map("players")
}

model Tournament {
  id                    String             @id @default(uuid())
  name                  String
  location              String?
  registrationStartDate DateTime?          @map("registration_start_date")
  registrationEndDate   DateTime?          @map("registration_end_date")
  gameFormula           String?            @map("game_formula")
  registrationFee       Decimal?           @map("registration_fee") @db.Decimal(10, 2)
  startDate             DateTime?          @map("start_date")
  endDate               DateTime?          @map("end_date")
  format                String
  category              String
  status                String             @default("upcoming")
  published             Boolean            @default(false)
  participantLimit      Int?               @map("participant_limit")
  groupCount            Int?               @map("group_count")
  qualifiersPerGroup    Int?               @map("qualifiers_per_group")
  organizationId        String?            @map("organization_id")
  organization          Organization?      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  players               TournamentPlayer[]
  matches               Match[]
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  @@index([startDate])
  @@index([status])
  @@index([organizationId])
  @@map("tournaments")
}

model TournamentPlayer {
  tournamentId String     @map("tournament_id")
  playerId     String     @map("player_id")
  seed         Int?
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player       Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@id([tournamentId, playerId])
  @@index([playerId])
  @@map("tournament_players")
}

model Match {
  id           String     @id @default(uuid())
  tournamentId String     @map("tournament_id")
  round        Int
  position     Int
  player1Id    String?    @map("player1_id")
  player2Id    String?    @map("player2_id")
  result       String?
  winnerId     String?    @map("winner_id")
  status       String     @default("pending")
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player1      Player?    @relation("MatchPlayer1", fields: [player1Id], references: [id], onDelete: SetNull)
  player2      Player?    @relation("MatchPlayer2", fields: [player2Id], references: [id], onDelete: SetNull)
  winner       Player?    @relation("MatchWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@index([tournamentId, round, position])
  @@map("matches")
}
